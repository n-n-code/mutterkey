PROJECT_NAME           = "mutterkey"
PROJECT_BRIEF          = "KDE-first push-to-talk transcription tool for KDE Plasma"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@MUTTERKEY_DOXYGEN_OUTPUT_DIR@"
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English
USE_MDFILE_AS_MAINPAGE = "@CMAKE_CURRENT_SOURCE_DIR@/docs/mainpage.md"

INPUT                  = "@CMAKE_CURRENT_SOURCE_DIR@/docs/mainpage.md" \
                         "@CMAKE_CURRENT_SOURCE_DIR@/src"
FILE_PATTERNS          = *.h \
                         *.md
RECURSIVE              = YES
EXCLUDE                = "@CMAKE_CURRENT_SOURCE_DIR@/third_party"
EXCLUDE_PATTERNS       = */build/* \
                         */build-*/* \
                         */cmake-build-*/* \
                         */CMakeFiles/* \
                         */*_autogen/*

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_IN_BODY_DOCS      = NO
INTERNAL_DOCS          = NO

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MULTILINE_CPP_IS_BRIEF = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = YES
WARN_LOGFILE           =

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_DOCBOOK       = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = NO
REFERENCES_RELATION    = NO
STRIP_FROM_PATH        = "@CMAKE_CURRENT_SOURCE_DIR@"
QUIET                  = YES
